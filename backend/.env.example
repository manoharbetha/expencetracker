APP_NAME="AI Financial Expense Tracker"
APP_ENV=development
API_PREFIX=/api/v1
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/financial_expense_tracker?retryWrites=true&w=majority
MONGODB_DB_NAME=financial_expense_tracker

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
